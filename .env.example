# ─── AMESCOTES ERP 환경변수 ───
# 로컬: 이 파일을 .env 로 복사 후 값 채우기
# 배포(Railway 등): 아래 값들을 플랫폼 환경변수 화면에 그대로 입력
#   ⚠️ VITE_* 는 빌드 시점에 클라이언트에 박히므로 배포 빌드 전에 반드시 설정돼 있어야 함

# Supabase (운영 DB) — 클라이언트에서 사용
VITE_SUPABASE_URL=https://linzfvhgswrnoukssqyi.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Anthropic (OCR / AI 어시스턴트용) — 서버에서 사용
ANTHROPIC_API_KEY=sk-ant-...

# ─── 공개 배포 접근 보호 (외부 URL 공유 시 필수) ───
# SHARE_PASS 를 설정하면 사이트 접속 시 브라우저 비밀번호 창이 뜸.
# 로컬/사내 LAN 에서는 비워두면 게이트 없음.
SHARE_USER=atlm
SHARE_PASS=

# ─── 선택: AI 에이전트 쓰기 기능 (샘플·발주 자동 등록 등) ───
# Supabase 콘솔 → Settings → API → service_role 키
SUPABASE_URL=https://linzfvhgswrnoukssqyi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 로컬 실행 포트 (배포 플랫폼은 자동으로 PORT 주입 → 아래 무시됨)
PORT=4000
